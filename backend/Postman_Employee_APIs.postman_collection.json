	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login Staff",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"staffCode\": \"NV001\",\n  \"role\": \"staff\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Đăng nhập nhân viên để lấy JWT token. Token sẽ tự động được lưu vào biến {{token}} sau khi login thành công."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.token) {",
									"        pm.collectionVariables.set(\"token\", jsonData.token);",
									"        console.log(\"✅ Token đã được lưu tự động vào biến 'token'\");",
									"        console.log(\"Token: \" + jsonData.token.substring(0, 50) + \"...\");",
									"    } else {",
									"        console.log(\"❌ Không tìm thấy token trong response\");",
									"    }",
									"} else {",
									"    console.log(\"❌ Login thất bại: \" + pm.response.code);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
